# Select which LLM provider each agent uses. Any of: anthropic | openai | google | groq
ANALYST_LLM_PROVIDER=anthropic
UI_EXPLORER_LLM_PROVIDER=anthropic
CODEGEN_LLM_PROVIDER=anthropic
EXECUTOR_LLM_PROVIDER=anthropic
ORCHESTRATOR_LLM_PROVIDER=anthropic

# Default model per provider (override per-agent with <AGENT>_LLM_MODEL)
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_MODEL=gpt-4o
GOOGLE_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile

# API keys — only the ones for providers you actually use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Runtime
LOG_LEVEL=INFO
OUTPUT_DIR=./output
